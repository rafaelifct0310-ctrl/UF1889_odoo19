<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_academy_student_tree" model="ir.ui.view">
        <field name="name">academy.student.tree</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <tree string="Students">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="tutoring_count"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_academy_student_form" model="ir.ui.view">
        <field name="name">academy.student.form</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="birth_date"/>
                            <field name="address"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Estadísticas">
                        <field name="tutoring_count"/>
                        <field name="last_tutoring_date"/>
                    </group>
                    <notebook>
                        <page string="Tutorías" name="tutoring">
                            <field name="tutoring_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>