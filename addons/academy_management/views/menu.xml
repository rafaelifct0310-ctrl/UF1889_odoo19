<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menú principal Academia -->
    <menuitem id="menu_academy_root"
              name="Academy"
              sequence="10"/>

    <!-- Acción para Student -->
    <record id="action_academy_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">academy.student</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primer estudiante
            </p>
        </field>
    </record>

    <menuitem id="menu_academy_student"
              name="Students"
              parent="menu_academy_root"
              action="action_academy_student"
              sequence="10"/>

    <!-- Acción para Tutoring -->
    <record id="action_academy_tutoring" model="ir.actions.act_window">
        <field name="name">Tutorings</field>
        <field name="res_model">academy.tutoring</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primera tutoría
            </p>
        </field>
    </record>

    <menuitem id="menu_academy_tutoring"
              name="Tutorings"
              parent="menu_academy_root"
              action="action_academy_tutoring"
              sequence="20"/>
</odoo>