<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_seguimientos" model="ir.ui.view">
        <field name="name">res.partner.form.seguimientos</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="city" position="after">
                <field name="seguimientos_count" string="Seguimientos"/>
            </field>
        </field>
    </record>

    <record id="view_partner_tree_seguimientos" model="ir.ui.view">
        <field name="name">res.partner.tree.seguimientos</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <field name="email" position="after">
                <field name="seguimientos_count" string="Seguimientos"/>
            </field>
        </field>
    </record>
</odoo>